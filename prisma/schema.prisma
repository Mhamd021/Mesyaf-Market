generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Role {
  ADMIN
  VENDOR
  DELIVERER
  CUSTOMER
}

enum Condition {
  NEW
  USED
}


model User {
  id           Int      @id @default(autoincrement())
  name         String  
  email        String   @unique
  password     String
  role         Role     @default(CUSTOMER)
  profileImage String?  
  phoneNumber  String?  
  address      String?  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendorProfile VendorProfile?

}

model VendorProfile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  shopName    String
  coverImage  String?   // Optional banner or logo
  description String?   // Optional about/shop info
  address     String?   // Human-readable address
  latitude    Float?    // For map display and proximity filtering
  longitude   Float?    // For map display and proximity filtering
  isVerified  Boolean   @default(false)
  isActive    Boolean  @default(true)
  rating      Float?    @default(0) // Calculated from product reviews
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt


  user        User      @relation(fields: [userId], references: [id])
  products    Product[]
}

model Product {
  id             Int       @id @default(autoincrement())
  vendorId       Int
  categoryId     Int
  name           String
  description    String?
  price          Float
  discountPrice  Float?    // Optional discounted price
  stockQuantity  Int       @default(0)
  condition      Condition @default(NEW)
  isAvailable    Boolean   @default(true)
  views          Int       @default(0) // Tracks how many times product is viewed
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  vendor         VendorProfile @relation(fields: [vendorId], references: [id])
  category       Category      @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  tags           ProductTag[] @relation("ProductTags")

}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}


model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  url       String
  altText   String?
  product   Product  @relation(fields: [productId], references: [id])
}

model ProductTag {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[] @relation("ProductTags")
}


